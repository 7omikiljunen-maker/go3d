{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": true,
        ".write": "data.exists() || (auth != null && root.child('users').child(auth.uid).child('paid').val() === true)"
      }
    },
    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": false
      }
    }
  }
}
