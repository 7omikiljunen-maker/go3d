{
  "rules": {
    "rooms": {
      "$roomId": {
        ".read": true,
        ".write": "(!data.exists() && auth != null && root.child('users').child(auth.uid).child('paid').val() === true) || (data.exists() && auth != null)",
        "chat": {
          "$msgId": {
            ".validate": "!newData.exists() || (newData.hasChildren(['player','text','ts']) && newData.child('text').isString() && newData.child('text').val().length > 0 && newData.child('text').val().length <= 500)"
          }
        }
      }
    },
    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": false
      }
    },
    "payments": {
      ".read":  false,
      ".write": false
    }
  }
}
